# AWS Configuration
# Copy this file to .env and replace placeholder values with your own
AWS_PROFILE=your-profile-name
AWS_REGION=us-east-1

# Model Configuration
MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# Agent Configuration
AGENT_NAME=cloud-ops-agent
AGENT_ALIAS=TSTALIASID

# cloud-ops-toolkit path (relative to this directory)
TOOLKIT_PATH=../cloud-ops-toolkit
